# ============= REQUIRED =============
AUTH_SECRET=                # 32-byte random, generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
DATA_DIR=./data

# ============= BOOTSTRAP =============
BOOTSTRAP_ADMIN_EMAIL=admin@local.test

# ============= DEMO DATA (optional) =============
# Set SEED_DEMO=true to seed a realistic 11-person, 3-team demo company on first boot.
# All demo users (*@acme.test) share DEMO_PASSWORD and can log in without a forced change.
SEED_DEMO=false
DEMO_PASSWORD=Password123!

# ============= OPTIONAL =============
LOG_LEVEL=info
SESSION_MAX_AGE=28800
LOCK_STALE_MS=10000
LOCK_HEARTBEAT_MS=5000
