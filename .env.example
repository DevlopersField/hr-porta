# ============= REQUIRED =============
AUTH_SECRET=                # 32-byte random, generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
DATA_DIR=./data
# REQUIRED for production (`next start` / any deploy): NextAuth v5 rejects every
# request with "UntrustedHost" unless the host is trusted. Behind a proxy
# (Railway/Fly/VPS+nginx) set this to true. Not needed in `next dev`.
AUTH_TRUST_HOST=true

# ============= BOOTSTRAP =============
BOOTSTRAP_ADMIN_EMAIL=admin@local.test

# ============= DEMO DATA (optional) =============
# Set SEED_DEMO=true to seed a realistic 11-person, 3-team demo company on first boot.
# All demo users (*@acme.test) share DEMO_PASSWORD and can log in without a forced change.
SEED_DEMO=false
DEMO_PASSWORD=Password123!

# ============= OPTIONAL =============
LOG_LEVEL=info
SESSION_MAX_AGE=28800
LOCK_STALE_MS=10000
LOCK_HEARTBEAT_MS=5000

# ============= EMAIL (optional, zero-cost) =============
# Leave unset to disable email entirely (the portal works without it).
# Any free SMTP works: Gmail app password, Brevo free tier, Mailgun sandbox.
# When set, new users / password resets receive their temp password by email.
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=you@gmail.com
#SMTP_PASS=your-app-password
#SMTP_FROM=HR Portal <you@gmail.com>
